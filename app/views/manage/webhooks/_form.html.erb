<%= form_for([:manage, @webhook]) do |f| %>
  <% if @webhook.errors.any? %>
    <div class="alert alert-danger" role="alert">
      <strong class="font-bold">
        <%= pluralize(@webhook.errors.count, "error") %>
        prohibited this webhook from being saved:
      </strong>

      <ul class="list-disc list-inside">
        <%- @webhook.errors.full_messages.each do |message| -%>
          <li><%= message %></li>
        <%- end -%>
      </ul>
    </div>
  <% end %>

  <div class="flex flex-col lg:flex-row">
    <div class="w-full lg:w-3/4 lg:mr-3">
       <div class="form-group">
        <%= f.label :name, class: 'control-label' %>
        <%= f.text_field :name, class: 'text_field form-control', placeholder: 'Deploy webhook' %>
      </div>

      <div class="form-group">
        <%= f.label :url, class: 'control-label' %>
        <%= f.url_field :url, class: 'text_field form-control', placeholder: 'https://example.com/webhooks/deploy' %>
      </div>

      <% unless @webhook.new_record? %>
        <div class="form-group">
          <%= f.label :secret, class: 'control-label' %>
          <div class="flex items-center gap-2">
            <input type="text" class="text_field form-control font-mono" value="<%= @webhook.secret %>" readonly>
          </div>
          <p class="help-block">Use this secret to verify the <code>X-Resumis-Signature</code> header on incoming requests.</p>
        </div>
      <% end %>
    </div>

    <div class="w-full lg:w-1/4 lg:pl-3">
      <div class="w-full rounded bg-white overflow-hidden shadow-lg px-6 py-4 mb-6">
        <h3 class="font-medium mb-4 text-gray-700">Options</h3>

        <div class="form-group">
          <div class="checkbox">
            <label>
              <%= f.check_box :enabled, class: 'form-checkbox' %> Enabled
            </label>
          </div>
        </div>
      </div>

      <div class="w-full rounded bg-white overflow-hidden shadow-lg px-6 py-4 mb-6">
        <h3 class="font-medium mb-4 text-gray-700">Resource Types</h3>

        <% Webhook::RESOURCE_TYPES.each do |type| %>
          <div class="checkbox">
            <label>
              <%= check_box_tag "webhook[resource_types][]", type,
                    @webhook.resource_types.include?(type),
                    class: 'form-checkbox',
                    id: "webhook_resource_types_#{type}" %>
              <%= type.capitalize %>
            </label>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="actionbar actionbar-fixed-bottom">
    <div class="actionbar-left">
      <%= link_to t('.cancel', default: t("helpers.links.cancel")),
                    manage_webhooks_path, class: 'btn btn-default' %>
    </div>
    <div class="actionbar-right">
      <% unless @webhook.new_record? %>
        <%= link_to t('.destroy', default: t("helpers.links.destroy")),
                    manage_webhook_path(@webhook),
                    method: :delete, data: { confirm: 'Are you sure?' },
                    class: 'btn btn-link link-danger' %>
      <% end %>
      <%= f.submit nil, class: 'btn btn-primary' %>
    </div>
  </div>
<% end %>
